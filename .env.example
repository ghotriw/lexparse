# Copy this file to `.env` and fill in real values.
#   cp .env.example .env

# Listen address
PARSER_ADDR=0.0.0.0:3001

# Unload model after N seconds idle
PARSER_IDLE_UNLOAD_SECS=10

# ORT arena allocator (set 0 to reduce RSS)
PARSER_CPU_ARENA=1

# ORT memory pattern optimization
PARSER_MEM_PATTERN=0

# Number of intra-op threads (uncomment to override)
# PARSER_INTRA_THREADS=4

# ─── correct_idioms binary ───
# Re-classifies lexicon entries tagged `idiom` into true figurative idioms vs
# fixed expressions / discourse markers. Output appended to dic/corrections.jsonl.
# Run:  cargo run --release --bin correct_idioms

# Gemini API key (required). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini model to use. Default: gemini-3.1-flash-lite-preview (cheap + fast).
# Override for higher quality (e.g. gemini-2.5-pro) or different cost/latency.
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Max Gemini requests per minute. 0 (default) = no limit.
# Set to match your tier's RPM quota to avoid 429 errors (free tier is ~15 RPM
# for flash-lite, paid tiers are higher — check your project quota).
GEMINI_RPM=12
